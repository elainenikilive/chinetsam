rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    match /rsvps/{rsvpId} {
      allow read: if true;
      allow create, update: if rsvpId is string && rsvpId.size() > 0 && rsvpId.size() <= 200
        && request.resource.data.name == rsvpId
        && request.resource.data.name is string && request.resource.data.name.size() <= 200
        && request.resource.data.attending is bool
        && request.resource.data.withPlusOne is bool
        && request.resource.data.plusOneName is string && request.resource.data.plusOneName.size() <= 200
        && request.resource.data.submittedAt is string && request.resource.data.submittedAt.size() <= 100;
      allow delete: if false;
    }
  }
}
